# Google Analytics (set in Vercel Project Settings -> Environment Variables)
NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX

# Brevo – email delivery for contact form
# Register at https://www.brevo.com, get the API key, and set it in Vercel Environment Variables
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
BREVO_FROM_EMAIL=no-reply@mail.akce.zivesklo.cz
BREVO_FROM_NAME="Živé Sklo"
CONTACT_TO=info@zivesklo.cz

# Optional anti-spam tuning
CONTACT_RATE_LIMIT_MAX=3
CONTACT_RATE_LIMIT_WINDOW_MS=600000
