{
  "name": "zive-sklo-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "dev:ip": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start",
    "preview": "next start --hostname 127.0.0.1 --port 3000",
    "preview:e2e": "next start --hostname 127.0.0.1 --port 3102",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:baseline": "playwright test tests/e2e/hero.spec.ts tests/e2e/navigation.spec.ts tests/e2e/a11y-smoke.spec.ts",
    "test:e2e:baseline:ci": "mkdir -p ./test-results && playwright test tests/e2e/hero.spec.ts tests/e2e/navigation.spec.ts tests/e2e/a11y-smoke.spec.ts --reporter=json > ./test-results/playwright-baseline.json",
    "perf:lighthouse": "npm run perf:lighthouse:desktop && npm run perf:lighthouse:mobile",
    "perf:lighthouse:desktop": "start-server-and-test \"npm run preview\" http://127.0.0.1:3000 \"node ./scripts/run-lighthouse.mjs desktop\"",
    "perf:lighthouse:mobile": "start-server-and-test \"npm run preview\" http://127.0.0.1:3000 \"node ./scripts/run-lighthouse.mjs mobile\"",
    "perf:lighthouse:baseline": "npm run build && npm run perf:lighthouse && node ./scripts/verify-lighthouse-thresholds.mjs"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "lighthouse": "^12.8.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "start-server-and-test": "^3.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
